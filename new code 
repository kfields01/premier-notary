node -e "
const fs = require('fs');
const pkg = JSON.parse(fs.readFileSync('package.json', 'utf8'));
pkg.devDependencies = pkg.devDependencies || {};
pkg.npmOptions = pkg.npmOptions || {};
fs.writeFileSync('.npmrc', 'legacy-peer-deps=true\n');
console.log('Done');
"
git add .npmrc && git commit -m "fix: add legacy-peer-deps for React 19 compatibility" && git push